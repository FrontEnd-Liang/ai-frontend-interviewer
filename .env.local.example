# 复制本文件为 .env.local 后填写你的 Key

# 你的 Google Gemini API Key（必填）
# 获取方式：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxx

# 可选：自定义模型，默认 gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# 可选：本机 HTTP 代理（国内直连 Google API 会超时，建议配上）
# 常见端口：Clash 7890 / v2rayN 10809 / 快柠檬 10792
# HTTPS_PROXY=http://127.0.0.1:7890

# Pinecone（启用 RAG 必填）
# 在 https://app.pinecone.io 的左侧 API Keys 菜单生成
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 你创建的索引名（维度必须为 768，与 text-embedding-004 一致；metric 选 cosine）
PINECONE_INDEX=ai-interviewer

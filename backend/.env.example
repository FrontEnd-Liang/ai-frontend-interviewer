# 复制为 backend/.env，或继续使用项目根目录的 .env.local（config 会自动加载）
# 变量名与 Next.js 版一致

GEMINI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=ai-interviewer

# 可选
# TAVILY_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase（对话记忆，可选；留空则仅内存对话、不落库）
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # 建议 service_role（仅后端）
# MEMORY_MAX_MESSAGES=30
